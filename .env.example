# Optional: set in Vercel → Project → Settings → Environment Variables
# when using a custom domain (e.g. https://panel-systems-manufacturing.vercel.app)
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Resend (contact form) — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Inbox for contact submissions (defaults to wolfjame@gmail.com for testing)
CONTACT_EMAIL=wolfjame@gmail.com
# Use onboarding@resend.dev until your domain is verified in Resend
# RESEND_FROM_EMAIL=Contact Form <onboarding@resend.dev>
# Production example after domain verification:
# RESEND_FROM_EMAIL=Panel Systems Manufacturing <info@roomdividers.org>
